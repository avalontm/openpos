{
  "name": "openpos",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "src/shared"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "dev:cli": "bun run src/cli.ts",
    "dev:tui": "cd src && bun run tui.ts",
    "typecheck": "tsc --noEmit",
    "seed": "bun run src/db/seed.ts",
    "import": "bun run src/db/import-csv.ts",
    "build": "echo 'Use bun run src/cli.ts'",
    "reinstall": "rm -rf node_modules bun.lock && bun install"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bun-types": "^1.3.12",
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "react": "^19.0.0",
    "ink": "^7.0.0",
    "ink-text-input": "^6.0.0",
    "drizzle-orm": "^0.36.4",
    "zustand": "^5.0.2"
  }
}